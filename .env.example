# Template for local secrets. Copy this file to `.env` and fill in real values.
# `.env` itself is gitignored.

# ENTSO-E Transparency Platform Web API Security Token.
# Get one at: https://transparency.entsoe.eu  (My Account Settings → Web API Security Token).
# Requires that API access has been activated for the account
# (email transparency@entsoe.eu to request).
ENTSOE_API_TOKEN=paste-your-token-here
